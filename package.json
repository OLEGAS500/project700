{
  "name": "ecommerce-incident-monitor",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @eim/web",
    "build": "npm run build -w @eim/web",
    "lint": "npm run lint -w @eim/web",
    "test": "vitest run",
    "test:postgres": "RUN_POSTGRES_TESTS=1 vitest run packages/db/src/postgres-smoke.test.ts packages/db/src/incidents/merchant-item-issues-postgres-smoke.test.ts packages/db/src/incidents/feed-merchant-correlation-postgres-smoke.test.ts packages/db/src/dashboard/cross-source-product-mapping-postgres-smoke.test.ts packages/worker/src/sitemap-postgres-smoke.test.ts packages/worker/src/merchant-center-status-postgres-smoke.test.ts packages/worker/src/merchant-center-item-issues-postgres-smoke.test.ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "seed:v01-demo": "tsx scripts/seed-v01-demo.ts seed",
    "advance:v01-demo:recovering": "tsx scripts/seed-v01-demo.ts recovering",
    "advance:v01-demo:resolved": "tsx scripts/seed-v01-demo.ts resolved",
    "cleanup:v01-demo": "tsx scripts/seed-v01-demo.ts cleanup",
    "seed:merchant-remediation-qa": "tsx scripts/seed-merchant-remediation-qa.ts",
    "cleanup:merchant-remediation-qa": "tsx scripts/seed-merchant-remediation-qa.ts --cleanup",
    "worker:telegram": "tsx apps/worker/src/run-telegram-alerts.ts",
    "worker:email": "tsx apps/worker/src/run-email-alerts.ts"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  }
}
